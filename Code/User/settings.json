{
  "eslint.alwaysShowStatus": true,

  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "typescript.tsdk": "node_modules/typescript/lib",
  "editor.formatOnSave": true,

  "python.formatting.autopep8Args": [
    "--max-line-length",
    "120",
    "--experimental"
  ],

  "keyboard.dispatch": "keyCode",
  "bracket-pair-colorizer-2.showHorizontalScopeLine": false,
  "bracket-pair-colorizer-2.showVerticalScopeLine": false,
  "bracket-pair-colorizer-2.colorMode": "Independent",

  "editor.wordWrap": "on",

  "editor.tabSize": 2,

  "vim.leader": "<space>",
  "vim.easymotion": true,
  "vim.autoindent": true,
  "vim.sneak": true,
  "vim.incsearch": true,

  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "t", "r"],
      "commands": ["workbench.action.terminal.toggleTerminal"]
    },
    {
      "before": ["<leader>", "1"],
      "commands": ["workbench.view.explorer"]
    },
    {
      "before": ["leader", "/"],
      "commands": [":nohl"]
    },
    {
      "before": ["leader", ";"],
      "commands": ["cursorEnd"]
    },
    {
      "before": ["leader", "0"],
      "commands": ["cursorHome"]
    },
    {
      "before": ["leader", "q"],
      "commands": ["workbench.action.nextEditor"]
    },
    {
      "before": ["<C-l>"],
      "commands": ["workbench.action.focusNextGroup"]
    },
    {
      "before": ["<C-h>"],
      "commands": ["workbench.action.focusPreviousGroup"]
    },
    {
      "before": ["leader", "<tab>"],
      "commands": ["workbench.action.previousEditor"]
    },
    {
      "before": ["leader", "f", "s"],
      "commands": [
        {
          "command": "workbench.action.files.save",
          "args": []
        }
      ]
    },
    {
      "before": ["leader", "c", "c"],
      "commands": ["editor.action.addCommentLine"]
    },
    {
      "before": ["leader", "c", "u"],
      "commands": ["editor.action.removeCommentLine"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<C-n>"],
      "after": ["g", "b"]
    }
  ],

  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false
  },
  "workbench.colorCustomizations": {
    "statusBar.background": "#8FBCBB",
    "statusBar.noFolderBackground": "#8FBCBB",
    "statusBar.debuggingBackground": "#8FBCBB",
    "statusBar.foreground": "#434C5E"
  },
  "workbench.colorTheme": "Darcula Theme from IntelliJ",
  "window.zoomLevel": -1,
  "editor.fontFamily": "JetBrains Mono, 'monospace', monospace, 'Droid Sans Fallback'",
  "window.menuBarVisibility": "toggle",
  "workbench.settings.editor": "json",
  "workbench.settings.useSplitJSON": true,
  "explorer.confirmDragAndDrop": false,

  "files.exclude": {
    "**/.git": false,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true
  }
}
